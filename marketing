def get_entities(method):

    date_from = (datetime.now() - timedelta(days=DAYS)).strftime("%Y-%m-%d")

    filter_field = ">=DATE_MODIFY" if FLAG == 1 else ">=DATE_CREATE"

    data = fetch_all(method, {
        "filter": {filter_field: date_from},
        "select": [
            "ID","TITLE","ASSIGNED_BY_ID",
            "STAGE_ID","STATUS_ID",
            "UTM_SOURCE","SOURCE_ID","ORIGIN_ID",
            "OPPORTUNITY","DATE_CREATE","DATE_MODIFY"
        ]
    })

    return data[:MAX_ITEMS]

# =========================
# COMMENTS
# =========================

def get_comments(entity_type, entity_id):
    data = fetch_all("crm.timeline.comment.list", {
        "filter": {"ENTITY_TYPE": entity_type, "ENTITY_ID": entity_id}
    })

    res = []
    for c in data[:20]:
        text = clean(c.get("COMMENT"))
        if text and "📞 Звонок (activity_id=" not in text:
            res.append((c.get("CREATED"), f"{format_time(c.get('CREATED'))} {text}"))

    return res

# =========================
# ACTIVITIES
# =========================

def get_activities(entity_type, entity_id):

    owner_type = 2 if entity_type == "deal" else 1

    data = fetch_all("crm.activity.list", {
        "filter": {
            "OWNER_TYPE_ID": owner_type,
            "OWNER_ID": entity_id
        }
    })

    res = []

    for a in data[:20]:

        t = a.get("START_TIME")
        if not t:
            continue

        if a.get("TYPE_ID") == 4:
            text = clean(a.get("DESCRIPTION"))
            if text:
                res.append((t, f"{format_time(t)} EMAIL: {text}"))

        elif a.get("TYPE_ID") == 2:
            res.append((t, f"{format_time(t)} Звонок"))

        elif a.get("SUBJECT"):
            res.append((t, f"{format_time(t)} {clean(a.get('SUBJECT'))}"))

    return res

# =========================
# DIALOG
# =========================

def build_dialog(entity, entity_type):

    comments = get_comments(entity_type, entity["ID"])
    activities = get_activities(entity_type, entity["ID"])

    all_items = comments + activities

    if not all_items:
        return ["Нет активностей"]

    all_items.sort(key=lambda x: parse_time(x[0]))

    return [x[1] for x in all_items]

