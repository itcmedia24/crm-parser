def get_source(entity):
    raw = (
        entity.get("ORIGIN_ID") or
        entity.get("UTM_SOURCE") or
        entity.get("SOURCE_ID") or
        ""
    )
    return SOURCE_CUSTOM_MAP.get(raw, raw)

