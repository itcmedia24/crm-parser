# =========================
# UTILS
# =========================

def safe_request(method, payload):
    try:
        r = session.post(BITRIX_WEBHOOK + method, json=payload, timeout=15)
        time.sleep(SLEEP)
        return r.json()
    except:
        return {}

def clean(text):
    text = re.sub(r"\[img\].*?\[/img\]", "", text or "")
    text = re.sub(r"<.*?>", "", text)
    text = text.replace("&nbsp;", " ")
    return text.strip()

def parse_time(t):
    try:
        if "+" in t:
            return datetime.strptime(t, "%Y-%m-%dT%H:%M:%S%z").timestamp()
        return datetime.strptime(t, "%Y-%m-%dT%H:%M:%S").timestamp()
    except:
        return 0

def format_time(t):
    try:
        if "+" in t:
            dt = datetime.strptime(t, "%Y-%m-%dT%H:%M:%S%z")
        else:
            dt = datetime.strptime(t, "%Y-%m-%dT%H:%M:%S")
        return dt.strftime("%d.%m %H:%M")
    except:
        return ""

# =========================
# PAGINATION
# =========================

def fetch_all(method, payload):
    start = 0
    result = []

    while True:
        payload["start"] = start
        data = safe_request(method, payload)

        batch = data.get("result", [])
        result.extend(batch)

        if "next" not in data:
            break

        start = data["next"]

    return result

# =========================
# STATUS MAP
# =========================

def get_status_map():
    result = {}

    leads = fetch_all("crm.status.list", {"filter": {"ENTITY_ID": "STATUS"}})
    for s in leads:
        result[s["STATUS_ID"]] = s["NAME"]

    categories = fetch_all("crm.dealcategory.list", {})
    for c in categories:
        stages = fetch_all("crm.dealcategory.stage.list", {"id": c["ID"]})
        for s in stages:
            result[s["STATUS_ID"]] = s["NAME"]
            result[f"C{c['ID']}:{s['STATUS_ID']}"] = s["NAME"]

    return result

STATUS_MAP = get_status_map()

def resolve_status(entity):
    raw = entity.get("STAGE_ID") or entity.get("STATUS_ID")

    if not raw:
        return "—"

    if raw in STATUS_CUSTOM_MAP:
        return STATUS_CUSTOM_MAP[raw]

    if raw in STATUS_MAP:
        return STATUS_MAP[raw]

    if ":" in raw:
        short = raw.split(":")[-1]

        if short in STATUS_CUSTOM_MAP:
            return STATUS_CUSTOM_MAP[short]

        if short in STATUS_MAP:
            return STATUS_MAP[short]

    return raw

